// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  FLEET_MANAGER
  DISPATCHER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(FLEET_MANAGER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

model Vehicle {
  id           String           @id @default(cuid())
  registration String           @unique
  make         String
  model        String
  year         Int
  type         String
  status          VehicleStatus    @default(AVAILABLE)
  mileage         Float
  capacity        Int              @default(0)
  acquisitionCost Int              @default(0)
  region          String           @default("Maharashtra")
  lastService     DateTime?
  healthScore     Float
  trips           Trip[]
  maintenance  MaintenanceLog[]
  fuelLogs     FuelLog[]
  expenses     Expense[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

model Driver {
  id              String       @id @default(cuid())
  name            String
  licenseNumber   String       @unique
  licenseExpiry   DateTime
  safetyScore     Float
  experienceYears Int
  tripsCompleted  Int          @default(0)
  status          DriverStatus @default(AVAILABLE)
  avatar          String?
  trips           Trip[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

enum TripStatus {
  DRAFT
  ASSIGNED
  DISPATCHED
  COMPLETED
  CANCELLED
}

model Trip {
  id                 String     @id @default(cuid())
  source             String
  destination        String
  vehicleId          String
  vehicle            Vehicle    @relation(fields: [vehicleId], references: [id])
  driverId           String
  driver             Driver     @relation(fields: [driverId], references: [id])
  cargo              String
  distance           Float
  weight             Float
  status             TripStatus @default(DRAFT)
  scheduledDeparture DateTime
  actualDeparture    DateTime?
  estimatedArrival   DateTime
  actualArrival      DateTime?
  expenses           Expense[]
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}

enum MaintenanceStatus {
  COMPLETED
  SCHEDULED
  IN_PROGRESS
}

model MaintenanceLog {
  id         String            @id @default(cuid())
  vehicleId  String
  vehicle    Vehicle           @relation(fields: [vehicleId], references: [id])
  service    String
  date       DateTime
  technician String
  cost       Float
  status     MaintenanceStatus @default(SCHEDULED)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

model FuelLog {
  id        String   @id @default(cuid())
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
  date      DateTime
  gallons   Float
  cost      Float
  location  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Expense {
  id        String   @id @default(cuid())
  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])
  tripId    String?
  trip      Trip?    @relation(fields: [tripId], references: [id])
  type      String   // e.g., Toll, Parking, Repair, Maintenance, Other
  amount    Float
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
